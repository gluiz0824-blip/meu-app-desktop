{
  "name": "social-media-studio",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema local de controle de tarefas para social media.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch backend/server.ts",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc -b && vite build",
    "start": "node dist-server/server.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.1",
    "@vitejs/plugin-react": "^6.0.3",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0"
  }
}
